generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
   url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  githubId     Int          @unique @map("github_id")
  username     String       @unique @db.VarChar(100)
  name         String?      @db.VarChar(200)
  avatarUrl    String?      @map("avatar_url")
  bio          String?
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  repositories Repository[]
  snapshots    Snapshot[]

  @@index([username], map: "idx_users_username")
  @@map("users")
}

model Snapshot {
  id           Int       @id @default(autoincrement())
  userId       Int?      @map("user_id")
  snapshotDate DateTime  @map("snapshot_date") @db.Date
  totalStars   Int?      @default(0) @map("total_stars")
  topLanguages Json?     @map("top_languages")
  commitsByDay Json?     @map("commits_by_day")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  user         User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate(sort: Desc)], map: "idx_snapshots_user_date")
  @@map("snapshots")
}

model Repository {
  id        Int       @id @default(autoincrement())
  userId    Int?      @map("user_id")
  githubId  Int       @map("github_id")
  name      String    @db.VarChar(200)
  language  String?   @db.VarChar(100)
  stars     Int?      @default(0)
  forks     Int?      @default(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(6)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, githubId])
  @@index([userId], map: "idx_repos_user_id")
  @@map("repositories")
}
