generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int          @id @default(autoincrement())
  githubId     Int          @unique @map("github_id")
  username     String       @unique @db.VarChar(100)
  name         String?      @db.VarChar(200)
  avatarUrl    String?      @map("avatar_url")
  bio          String?
  createdAt    DateTime?    @default(now()) @map("created_at") @db.Timestamp(6)
  followers    Int          @default(0)
  following    Int          @default(0)
  publicRepos  Int          @default(0) @map("public_repos")
  stats        Stats?
  repositories Repository[]
  snapshots    Snapshot[]
  lastViewedAt  DateTime? 
  lastSyncedAt  DateTime? 

  @@index([username], map: "idx_users_username")
  @@map("users")
}

model Snapshot {
  id           Int       @id @default(autoincrement())
  userId       Int     @map("user_id")
  snapshotDate DateTime  @map("snapshot_date") @db.Date
  totalStars   Int      @default(0) @map("total_stars")
  totalRepos   Int       @default(0)
  totalForks   Int        @default(0)
  totalWatches Int       @default(0)
  followers     Int      @default(0)
  totalCommits  Int      @default(0)
  totalContributionsYear Int   @default(0)
  currentStreakDays Int       @default(0)
  longestStreakDays  Int      @default(0)
  activeDaysCount   Int      @default(0)

   overallScore              Float   @default(0)
  percentile                Float    @default(0)

  
  activeWeeks               Int    @default(0)
   consistencyScore          Float    @default(0) 
  activityScore             Float    @default(0)
 impactScore               Float    @default(0)
  diversityScore           Float    @default(0)
  repositoryScore          Float    @default(0)
  reachScore               Float     @default(0)

   



  

  
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, snapshotDate])
  @@index([userId, snapshotDate(sort: Desc)], map: "idx_snapshots_user_date")
  @@map("snapshots")
}

model Repository {
  id          Int       @id @default(autoincrement())
  userId      Int?      @map("user_id")
  githubId    Int       @map("github_id")
  name        String    @db.VarChar(200)
  language    String?   @db.VarChar(100)
  stars       Int?      @default(0)
  forks       Int?      @default(0)
  watchers    Int?      @default(0)
  updatedAt   DateTime? @map("updated_at") @db.Timestamp(6)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  description String?
  homepage    String?   @map("homepage")
  repoUrl     String    @map("repo_url")

  @@unique([userId, githubId])
  @@index([userId], map: "idx_repos_user_id")
  @@map("repositories")
}

model Stats {
  id     Int  @id @default(autoincrement())
  userId Int  @unique @map("user_id")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  devScore Int
  stats    Json

  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([devScore(sort:Desc)])
  @@map("stats")
}
